FROM node:22-alpine

WORKDIR /app

# Copy backend files
COPY backend/package*.json ./backend/
RUN cd backend && npm install --production

COPY backend/ ./backend/

# Copy .env if exists
COPY .env* ./

# Build TypeScript
RUN cd backend && npx tsc || true

WORKDIR /app/backend

# Create data directory
RUN mkdir -p data

EXPOSE 3000

CMD ["node", "dist/index.js"]
