{
  "version": 2,
  "buildCommand": "npm run build --prefix=backend && npm run build --prefix=frontend",
  "outputDirectory": "frontend/dist",
  "publicallySourceMaps": true,
  "functions": {
    "api/**": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "/index.html"
    }
  ]
}
